generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  blocked
}

enum ProductStatus {
  active
  inactive
}

enum ProductType {
  medicine
  otc
  medical_supply
  hygiene_disinfection
  related_misc
}

enum SupplierStatus {
  active
  inactive
}

enum PurchaseStatus {
  draft
  received
  cancelled
}

enum InventoryBatchStatus {
  active
  depleted
  cancelled
}

enum InventoryMovementType {
  purchase_received
  purchase_cancelled
  inventory_adjustment
  sale_confirmed
  sale_cancelled
  sale_returned
}

enum CashSessionStatus {
  open
  closed
}

enum SaleStatus {
  confirmed
  cancelled
  returned
}

enum PaymentMethod {
  cash
}

enum PaymentStatus {
  paid
  reverted
  cancelled
  refunded
}

enum PreparedInvoiceStatus {
  prepared
  cancelled
}

enum PendingCartStatus {
  active
  converted
  discarded
  expired
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  passwordHash         String
  fullName             String
  roleId               String
  role                 Role                  @relation(fields: [roleId], references: [id])
  status               UserStatus            @default(active)
  lastLoginAt          DateTime?
  auditLogs            AuditLog[]            @relation("AuditActor")
  createdPurchases     Purchase[]            @relation("PurchaseCreatedBy")
  receivedPurchases    Purchase[]            @relation("PurchaseReceivedBy")
  inventoryMovements   InventoryMovement[]   @relation("InventoryMovementActor")
  inventoryAdjustments InventoryAdjustment[] @relation("InventoryAdjustmentActor")
  openedCashSessions   CashSession[]         @relation("CashSessionOpenedBy")
  closedCashSessions   CashSession[]         @relation("CashSessionClosedBy")
  soldSales            Sale[]                @relation("SaleSeller")
  cancelledSales       Sale[]                @relation("SaleCancelledBy")
  preparedInvoices     PreparedInvoice[]     @relation("PreparedInvoiceSeller")
  cancelledInvoices    PreparedInvoice[]     @relation("PreparedInvoiceCancelledBy")
  saleReturns          SaleReturn[]          @relation("SaleReturnActor")
  pendingCarts         PendingCart[]         @relation("PendingCartOwner")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  displayName String
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  module      String
  description String
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())

  @@id([roleId, permissionId])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  actorUserId String?
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  entityType  String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model ProductCategory {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  status      ProductStatus @default(active)
  products    Product[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Unit {
  id            String         @id @default(cuid())
  name          String         @unique
  abbreviation  String         @unique
  description   String?
  status        ProductStatus  @default(active)
  baseProducts  Product[]      @relation("ProductBaseUnit")
  productUnits  ProductUnit[]
  purchaseItems PurchaseItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Product {
  id                   String                @id @default(cuid())
  internalCode         String                @unique
  barcode              String?               @unique
  commercialName       String
  genericName          String?
  description          String?
  type                 ProductType
  categoryId           String
  category             ProductCategory       @relation(fields: [categoryId], references: [id])
  baseUnitId           String
  baseUnit             Unit                  @relation("ProductBaseUnit", fields: [baseUnitId], references: [id])
  supplierId           String
  supplier             Supplier              @relation(fields: [supplierId], references: [id])
  laboratoryName       String?
  sanitaryRegistration String?
  isMedicine           Boolean               @default(false)
  isOverTheCounter     Boolean               @default(false)
  requiresPrescription Boolean               @default(false)
  isInventoryTracked   Boolean               @default(true)
  requiresBatch        Boolean               @default(true)
  requiresExpiration   Boolean               @default(true)
  minimumStock         Decimal               @default(0) @db.Decimal(12, 4)
  salePrice            Decimal               @db.Decimal(12, 2)
  status               ProductStatus         @default(active)
  units                ProductUnit[]
  purchaseItems        PurchaseItem[]
  inventoryBatches     InventoryBatch[]
  inventoryMovements   InventoryMovement[]
  inventoryAdjustments InventoryAdjustment[]
  saleItems            SaleItem[]
  preparedInvoiceItems PreparedInvoiceItem[]
  saleReturnItems      SaleReturnItem[]
  pendingCartItems     PendingCartItem[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([categoryId])
  @@index([baseUnitId])
  @@index([supplierId])
  @@index([commercialName])
}

model ProductUnit {
  id               String   @id @default(cuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitId           String
  unit             Unit     @relation(fields: [unitId], references: [id])
  conversionFactor Decimal  @db.Decimal(12, 4)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([productId, unitId])
  @@index([unitId])
}

model Supplier {
  id           String         @id @default(cuid())
  businessName String
  nit          String?        @unique
  phone        String?
  address      String?
  contactName  String?
  status       SupplierStatus @default(active)
  products     Product[]
  purchases    Purchase[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([businessName])
  @@index([status])
  @@index([createdAt])
}

model Purchase {
  id               String         @id @default(cuid())
  supplierId       String
  supplier         Supplier       @relation(fields: [supplierId], references: [id])
  purchaseDate     DateTime       @db.Date
  status           PurchaseStatus @default(draft)
  totalAmount      Decimal        @default(0) @db.Decimal(12, 2)
  createdByUserId  String
  createdByUser    User           @relation("PurchaseCreatedBy", fields: [createdByUserId], references: [id])
  receivedByUserId String?
  receivedByUser   User?          @relation("PurchaseReceivedBy", fields: [receivedByUserId], references: [id])
  receivedAt       DateTime?
  cancelledAt      DateTime?
  notes            String?
  receiveNotes     String?
  cancelReason     String?
  items            PurchaseItem[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([supplierId])
  @@index([purchaseDate])
  @@index([status])
  @@index([createdByUserId])
  @@index([receivedByUserId])
  @@index([supplierId, purchaseDate])
  @@index([status, purchaseDate])
}

model PurchaseItem {
  id                 String          @id @default(cuid())
  purchaseId         String
  purchase           Purchase        @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId          String
  product            Product         @relation(fields: [productId], references: [id])
  unitId             String
  unit               Unit            @relation(fields: [unitId], references: [id])
  quantity           Decimal         @db.Decimal(12, 4)
  unitCost           Decimal         @db.Decimal(12, 2)
  conversionFactor   Decimal         @db.Decimal(12, 4)
  baseQuantity       Decimal         @db.Decimal(12, 4)
  baseUnitCost       Decimal         @db.Decimal(12, 4)
  lineTotal          Decimal         @db.Decimal(12, 2)
  isInventoryTracked Boolean         @default(true)
  batchNumber        String?
  expirationDate     DateTime?       @db.Date
  inventoryBatch     InventoryBatch?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([purchaseId])
  @@index([productId])
  @@index([unitId])
  @@index([batchNumber])
  @@index([expirationDate])
  @@index([productId, batchNumber])
  @@index([productId, expirationDate])
}

model InventoryBatch {
  id                String                @id @default(cuid())
  purchaseItemId    String                @unique
  purchaseItem      PurchaseItem          @relation(fields: [purchaseItemId], references: [id])
  productId         String
  product           Product               @relation(fields: [productId], references: [id])
  originalQuantity  Decimal               @db.Decimal(12, 4)
  availableQuantity Decimal               @db.Decimal(12, 4)
  baseUnitCost      Decimal               @db.Decimal(12, 4)
  batchNumber       String?
  expirationDate    DateTime?             @db.Date
  status            InventoryBatchStatus  @default(active)
  movements         InventoryMovement[]
  adjustments       InventoryAdjustment[]
  saleItemBatches   SaleItemBatch[]
  saleReturnItems   SaleReturnItem[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([productId])
  @@index([batchNumber])
  @@index([expirationDate])
  @@index([status])
  @@index([productId, status])
  @@index([productId, batchNumber])
  @@index([productId, expirationDate])
  @@index([status, expirationDate])
}

model InventoryAdjustment {
  id                 String         @id @default(cuid())
  batchId            String
  batch              InventoryBatch @relation(fields: [batchId], references: [id])
  productId          String
  product            Product        @relation(fields: [productId], references: [id])
  previousQuantity   Decimal        @db.Decimal(12, 4)
  countedQuantity    Decimal        @db.Decimal(12, 4)
  differenceQuantity Decimal        @db.Decimal(12, 4)
  reason             String
  actorUserId        String?
  actorUser          User?          @relation("InventoryAdjustmentActor", fields: [actorUserId], references: [id])
  createdAt          DateTime       @default(now())

  @@index([batchId])
  @@index([productId])
  @@index([actorUserId])
  @@index([createdAt])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  batchId         String
  batch           InventoryBatch        @relation(fields: [batchId], references: [id])
  productId       String
  product         Product               @relation(fields: [productId], references: [id])
  type            InventoryMovementType
  quantityBase    Decimal               @db.Decimal(12, 4)
  unitCostBase    Decimal               @db.Decimal(12, 4)
  referenceType   String
  referenceId     String
  referenceItemId String?
  saleItemBatch   SaleItemBatch?
  saleReturnItem  SaleReturnItem?
  actorUserId     String?
  actorUser       User?                 @relation("InventoryMovementActor", fields: [actorUserId], references: [id])
  reason          String?
  createdAt       DateTime              @default(now())

  @@index([batchId])
  @@index([productId])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([referenceItemId])
  @@index([actorUserId])
  @@index([createdAt])
  @@index([productId, createdAt])
  @@index([productId, type])
  @@index([batchId, createdAt])
}

model CashSession {
  id                String            @id @default(cuid())
  correlativeNumber Int               @unique
  correlativeCode   String            @unique
  openedByUserId    String
  openedByUser      User              @relation("CashSessionOpenedBy", fields: [openedByUserId], references: [id])
  closedByUserId    String?
  closedByUser      User?             @relation("CashSessionClosedBy", fields: [closedByUserId], references: [id])
  sales             Sale[]
  payments          Payment[]
  initialAmount     Decimal           @db.Decimal(12, 2)
  countedAmount     Decimal?          @db.Decimal(12, 2)
  expectedAmount    Decimal           @default(0) @db.Decimal(12, 2)
  differenceAmount  Decimal?          @db.Decimal(12, 2)
  status            CashSessionStatus @default(open)
  openingNote       String?
  closingNote       String?
  openedAt          DateTime          @default(now())
  closedAt          DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([openedByUserId])
  @@index([closedByUserId])
  @@index([status])
  @@index([openedAt])
  @@index([closedAt])
  @@index([openedByUserId, status])
}

model Sale {
  id                   String            @id @default(cuid())
  correlativeNumber    Int               @unique
  correlativeCode      String            @unique
  sellerUserId         String
  sellerUser           User              @relation("SaleSeller", fields: [sellerUserId], references: [id])
  cancelledByUserId    String?
  cancelledByUser      User?             @relation("SaleCancelledBy", fields: [cancelledByUserId], references: [id])
  cashSessionId        String
  cashSession          CashSession       @relation(fields: [cashSessionId], references: [id])
  status               SaleStatus        @default(confirmed)
  totalAmount          Decimal           @default(0) @db.Decimal(12, 2)
  totalCost            Decimal           @default(0) @db.Decimal(12, 2)
  totalMargin          Decimal           @default(0) @db.Decimal(12, 2)
  confirmedAt          DateTime          @default(now())
  cancelledAt          DateTime?
  cancelReason         String?
  items                SaleItem[]
  payment              Payment?
  preparedInvoices     PreparedInvoice[]
  saleReturn           SaleReturn?
  convertedPendingCart PendingCart?      @relation("PendingCartConvertedSale")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([sellerUserId])
  @@index([cancelledByUserId])
  @@index([cashSessionId])
  @@index([status])
  @@index([confirmedAt])
  @@index([sellerUserId, confirmedAt])
  @@index([cashSessionId, confirmedAt])
}

model SaleItem {
  id                   String                @id @default(cuid())
  saleId               String
  sale                 Sale                  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId            String
  product              Product               @relation(fields: [productId], references: [id])
  internalCode         String
  barcode              String?
  commercialName       String
  genericName          String?
  baseUnitId           String
  baseUnitName         String
  baseUnitAbbreviation String
  unitPrice            Decimal               @db.Decimal(12, 2)
  quantity             Int
  subtotal             Decimal               @db.Decimal(12, 2)
  totalCost            Decimal               @default(0) @db.Decimal(12, 2)
  margin               Decimal               @default(0) @db.Decimal(12, 2)
  consumptions         SaleItemBatch[]
  preparedInvoiceItems PreparedInvoiceItem[]
  returnItems          SaleReturnItem[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([saleId])
  @@index([productId])
  @@index([saleId, productId])
}

model SaleItemBatch {
  id                  String             @id @default(cuid())
  saleItemId          String
  saleItem            SaleItem           @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  batchId             String
  batch               InventoryBatch     @relation(fields: [batchId], references: [id])
  quantity            Decimal            @db.Decimal(12, 4)
  unitCostBase        Decimal            @db.Decimal(12, 4)
  totalCost           Decimal            @db.Decimal(12, 2)
  inventoryMovementId String?            @unique
  inventoryMovement   InventoryMovement? @relation(fields: [inventoryMovementId], references: [id])
  returnItems         SaleReturnItem[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([saleItemId])
  @@index([batchId])
  @@index([saleItemId, batchId])
}

model Payment {
  id             String        @id @default(cuid())
  saleId         String        @unique
  sale           Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  cashSessionId  String
  cashSession    CashSession   @relation(fields: [cashSessionId], references: [id])
  saleReturn     SaleReturn?
  method         PaymentMethod @default(cash)
  saleTotal      Decimal       @db.Decimal(12, 2)
  receivedAmount Decimal       @db.Decimal(12, 2)
  changeAmount   Decimal       @db.Decimal(12, 2)
  refundAmount   Decimal?      @db.Decimal(12, 2)
  status         PaymentStatus @default(paid)
  paidAt         DateTime      @default(now())
  reversedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([cashSessionId])
  @@index([status])
  @@index([paidAt])
  @@index([cashSessionId, paidAt])
}

model PreparedInvoice {
  id                   String                @id @default(cuid())
  correlativeNumber    Int                   @unique
  correlativeCode      String                @unique
  saleId               String
  sale                 Sale                  @relation(fields: [saleId], references: [id])
  sellerUserId         String
  sellerUser           User                  @relation("PreparedInvoiceSeller", fields: [sellerUserId], references: [id])
  status               PreparedInvoiceStatus @default(prepared)
  saleCorrelativeCode  String
  cashSessionId        String
  cashSessionCode      String
  sellerName           String
  sellerEmail          String
  customerNit          String                @default("0")
  customerBusinessName String                @default("Consumidor final")
  fiscalNotes          String?
  totalAmount          Decimal               @db.Decimal(12, 2)
  preparedAt           DateTime              @default(now())
  cancelledAt          DateTime?
  cancelledByUserId    String?
  cancelledByUser      User?                 @relation("PreparedInvoiceCancelledBy", fields: [cancelledByUserId], references: [id])
  cancelReason         String?
  items                PreparedInvoiceItem[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([saleId])
  @@index([sellerUserId])
  @@index([status])
  @@index([preparedAt])
  @@index([cancelledByUserId])
  @@index([saleId, status])
  @@index([status, preparedAt])
}

model PreparedInvoiceItem {
  id                   String          @id @default(cuid())
  preparedInvoiceId    String
  preparedInvoice      PreparedInvoice @relation(fields: [preparedInvoiceId], references: [id], onDelete: Cascade)
  saleItemId           String
  saleItem             SaleItem        @relation(fields: [saleItemId], references: [id])
  productId            String
  product              Product         @relation(fields: [productId], references: [id])
  internalCode         String
  barcode              String?
  commercialName       String
  genericName          String?
  baseUnitId           String
  baseUnitName         String
  baseUnitAbbreviation String
  unitPrice            Decimal         @db.Decimal(12, 2)
  quantity             Int
  subtotal             Decimal         @db.Decimal(12, 2)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([preparedInvoiceId])
  @@index([saleItemId])
  @@index([productId])
}

model SaleReturn {
  id           String           @id @default(cuid())
  saleId       String           @unique
  sale         Sale             @relation(fields: [saleId], references: [id])
  paymentId    String           @unique
  payment      Payment          @relation(fields: [paymentId], references: [id])
  actorUserId  String
  actorUser    User             @relation("SaleReturnActor", fields: [actorUserId], references: [id])
  reason       String
  refundAmount Decimal          @db.Decimal(12, 2)
  returnedAt   DateTime         @default(now())
  items        SaleReturnItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([actorUserId])
  @@index([returnedAt])
  @@index([saleId, returnedAt])
  @@index([actorUserId, returnedAt])
}

model SaleReturnItem {
  id                  String             @id @default(cuid())
  saleReturnId        String
  saleReturn          SaleReturn         @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  saleItemId          String
  saleItem            SaleItem           @relation(fields: [saleItemId], references: [id])
  saleItemBatchId     String
  saleItemBatch       SaleItemBatch      @relation(fields: [saleItemBatchId], references: [id])
  batchId             String
  batch               InventoryBatch     @relation(fields: [batchId], references: [id])
  productId           String
  product             Product            @relation(fields: [productId], references: [id])
  inventoryMovementId String?            @unique
  inventoryMovement   InventoryMovement? @relation(fields: [inventoryMovementId], references: [id])
  quantity            Decimal            @db.Decimal(12, 4)
  unitCostBase        Decimal            @db.Decimal(12, 4)
  refundUnitPrice     Decimal            @db.Decimal(12, 2)
  refundSubtotal      Decimal            @db.Decimal(12, 2)
  batchNumber         String?
  expirationDate      DateTime?          @db.Date
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([saleReturnId, saleItemBatchId])
  @@index([saleReturnId])
  @@index([saleItemId])
  @@index([saleItemBatchId])
  @@index([batchId])
  @@index([productId])
}

model PendingCart {
  id                   String            @id @default(cuid())
  ownerUserId          String
  ownerUser            User              @relation("PendingCartOwner", fields: [ownerUserId], references: [id])
  status               PendingCartStatus @default(active)
  name                 String?
  note                 String?
  referenceTotalAmount Decimal           @default(0) @db.Decimal(12, 2)
  expiresAt            DateTime
  expiredAt            DateTime?
  discardedAt          DateTime?
  discardReason        String?
  convertedAt          DateTime?
  convertedSaleId      String?           @unique
  convertedSale        Sale?             @relation("PendingCartConvertedSale", fields: [convertedSaleId], references: [id])
  items                PendingCartItem[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([ownerUserId])
  @@index([status])
  @@index([expiresAt])
  @@index([ownerUserId, status])
  @@index([ownerUserId, expiresAt])
}

model PendingCartItem {
  id                   String      @id @default(cuid())
  pendingCartId        String
  pendingCart          PendingCart @relation(fields: [pendingCartId], references: [id], onDelete: Cascade)
  productId            String
  product              Product     @relation(fields: [productId], references: [id])
  internalCode         String
  barcode              String?
  commercialName       String
  genericName          String?
  baseUnitId           String
  baseUnitName         String
  baseUnitAbbreviation String
  referenceUnitPrice   Decimal     @db.Decimal(12, 2)
  quantity             Int
  referenceSubtotal    Decimal     @db.Decimal(12, 2)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@unique([pendingCartId, productId])
  @@index([pendingCartId])
  @@index([productId])
}
